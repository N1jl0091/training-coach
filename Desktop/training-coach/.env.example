# Copy this to .env for local dev — never commit .env
# Add all of these in Railway → your project → Variables

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI
OPENAI_API_KEY=

# Intervals.icu
INTERVALS_API_KEY=
INTERVALS_ATHLETE_ID=

# Strava
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=        # any random string you choose e.g. mycoach2024

# Railway (set automatically by Railway, copy your public domain here for local dev)
RAILWAY_PUBLIC_DOMAIN=

# Database path (Railway volume must be mounted at /data)
DB_PATH=/data/coach.db
